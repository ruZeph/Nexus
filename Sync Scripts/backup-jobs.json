{
  "settings": {
    "continueOnJobError": true,
    "defaultOperation": "sync",
    "logRetentionCount": 10,
    "defaultExtraArgs": [
      "--retries", "5",
      "--retries-sleep", "15s",
      "--contimeout", "30s",
      "--timeout", "2m",
      "--exclude", "*.ffs_db",
      "--exclude", "*.swp",
      "--exclude", "*.lock"
    ]
  },
  "profiles": {
    "docs-small-files": {
      "operation": "sync",
      "extraArgs": [
        "--transfers", "8",
        "--checkers", "16",
        "--fast-list",
        "--exclude", "~$*"
      ]
    },
    "playnite-restic": {
      "operation": "sync",
      "extraArgs": [
        "--transfers", "1",
        "--checkers", "2",
        "--no-update-modtime",
        "--fast-list",
        "--checksum"
      ]
    }
  },
  "jobs": [
    {
      "name": "office-docs-backup",
      "enabled": true,
      "profile": "docs-small-files",
      "source": "C:\\Users\\Avisek\\Documents\\Office Docs",
      "dest": "GDrive_Main:Documents/Office_Docs",
      "extraArgs": [
        "--metadata"
      ]
    },
    {
      "name": "playnite-backup",
      "enabled": true,
      "profile": "playnite-restic",
      "source": "C:\\Custom User\\Ludusavi\\PlayniteBackups",
      "dest": "GDrive_Main:backups/playnite-restic",
      "extraArgs": [
        "--update"
      ]
    }
  ]
}